<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.greg.shout.capslock-remap</string>

  <!-- Apply Caps Lock → F19 at the HID layer using Apple's built-in
       hidutil. This is the same effect Karabiner-Elements would have
       had, but with zero permissions, no system extension, and no
       background daemon. The mapping only persists for the current
       login session, so this LaunchAgent re-applies it at every login.

       The decimal-looking values are HID Usage Page 7 (Keyboard) plus
       a usage code: 0x700000039 = Caps Lock, 0x70000006E = F19.        -->
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/hidutil</string>
    <string>property</string>
    <string>--set</string>
    <string>{"UserKeyMapping":[{"HIDKeyboardModifierMappingSrc":0x700000039,"HIDKeyboardModifierMappingDst":0x70000006E}]}</string>
  </array>

  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
